# Copy this to .env and fill in real values.

# --- Embeddings (Layer 2) ---
VOYAGE_API_KEY=pa-...              # Used for embeddings (voyage-3 or voyage-3-lite)

# --- Layer 3 agent models ---
# Nemotron (NVIDIA NIM): fact extractor, context, perspective/debate. Key: nvapi-...
NVIDIA_API_KEY=nvapi-...
# Gemini: primary-source verifier + editor/hallucination auditor. Key: AIza... (or AQ....)
GEMINI_API_KEY=...
# Optional model overrides. NOTE: gemini-2.5-flash is retired for new keys (404);
# gemini-flash-lite-latest is the reliable default. Use gemini-flash-latest /
# gemini-2.5-pro for higher quality if your quota allows.
# NEMOTRON_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5   # reliable JSON; nano models emit prose
# GEMINI_MODEL=gemini-flash-lite-latest
# LLM_TIMEOUT=120                  # per-request seconds
# ANTHROPIC_API_KEY=sk-ant-...     # optional; not used by the default router

# --- Database ---
# Local dev: matches infra/docker-compose.yml
DATABASE_URL=postgresql://grounded:grounded@localhost:5432/grounded

# --- Runtime ---
GROUNDED_ENV=dev                   # dev | prod
LOG_LEVEL=INFO
OUTPUT_DIR=./output                # Where markdown articles are written
EMBEDDING_BACKEND=voyage           # voyage | local
CLUSTER_SIMILARITY=0.80
